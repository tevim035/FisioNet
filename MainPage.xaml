<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FIsioNet.MainPage"
             Title="Login"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">
        <!-- CONTEÚDO PRINCIPAL -->
        <ScrollView Grid.Row="0" VerticalOptions="Center">
            <VerticalStackLayout Padding="40,20,40,20">
                <Label Text="FisioNet" FontSize="42" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Black" Margin="0,0,0,35" SemanticProperties.HeadingLevel="Level1" />

                <!-- Formulário -->
                <VerticalStackLayout Spacing="12">
                    <Border BackgroundColor="#FAFAFA" Stroke="#DBDBDB" StrokeThickness="1" StrokeShape="RoundRectangle 5" HeightRequest="48">
                        <Entry x:Name="EntryLoginUsuario" Placeholder="Telefone, nome de usuário ou email" FontSize="14" BackgroundColor="Transparent" TextColor="Black" Margin="10,0" SemanticProperties.Description="Entre com sua conta google ou nome de usuário." />
                    </Border>
                    <Border BackgroundColor="#FAFAFA" Stroke="#DBDBDB" StrokeThickness="1" StrokeShape="RoundRectangle 5" HeightRequest="48">
                        <Entry x:Name="EntryLoginSenha" Placeholder="Senha" IsPassword="True" FontSize="14" BackgroundColor="Transparent" TextColor="Black" Margin="10,0"/>
                    </Border>
                </VerticalStackLayout>

                <Label Text="Esqueceu a senha?" TextColor="#2A7B4A" FontSize="12" FontAttributes="Bold" HorizontalOptions="End" Margin="0,15,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer />
                    </Label.GestureRecognizers>
                </Label>

                <Button x:Name="BtnEntrar" Text="Entrar" BackgroundColor="#2A7B4A" TextColor="White" CornerRadius="8" HeightRequest="45" FontAttributes="Bold" FontSize="14" Margin="0,20,0,0" SemanticProperties.Hint="Entra no sistema" Clicked="BtnEntrar_Clicked" />

                <Grid ColumnDefinitions="*, Auto, *" Margin="0,25">
                    <BoxView Grid.Column="0" HeightRequest="1" Color="#DBDBDB" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="OU" TextColor="#8E8E8E" FontSize="13" FontAttributes="Bold" Margin="15,0" VerticalOptions="Center" />
                    <BoxView Grid.Column="2" HeightRequest="1" Color="#DBDBDB" VerticalOptions="Center" />
                </Grid>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Border HeightRequest="20" WidthRequest="20" StrokeShape="RoundRectangle 10" BackgroundColor="#2A7B4A" Stroke="Transparent" Padding="0">
                        <Label Text="G" TextColor="White" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Entrar com o Google" TextColor="#2A7B4A" FontSize="14" FontAttributes="Bold" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- RODAPÉ -->
        <VerticalStackLayout Grid.Row="1">
            <BoxView HeightRequest="1" Color="#DBDBDB" />
            <HorizontalStackLayout HorizontalOptions="Center" Padding="0,15,0,25" Spacing="4">
                <Label Text="Não tem uma conta?" TextColor="#8E8E8E" FontSize="13" VerticalOptions="Center" />
                <Label Text="Cadastre-se" TextColor="#2A7B4A" FontSize="13" FontAttributes="Bold" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <!-- EVENTO DE CLIQUE ADICIONADO AQUI -->
                        <TapGestureRecognizer Tapped="OnCadastrarTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Grid>
</ContentPage>