<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FIsioNet.Views.PostPage"
             Title="PostPage">

    <Grid RowDefinitions="Auto,*">

        <!-- Bônus: deslizar para a direita (sentido inverso de como se chega aqui) também volta pro Feed -->
        <Grid.GestureRecognizers>
            <SwipeGestureRecognizer Direction="Right" Swiped="BtnVoltar_Clicked" />
        </Grid.GestureRecognizers>

        <!-- Cabeçalho: seta de voltar + título, mesma posição do "‹ Novo Caso Clínico" no Figma -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="Auto,*"
            Padding="8,16"
            ColumnSpacing="8">

            <Button
                Grid.Column="0"
                x:Name="btnVoltar"
                Text="&#8592;"
                FontSize="20"
                WidthRequest="44"
                HeightRequest="44"
                Padding="0"
                CornerRadius="22"
                BackgroundColor="Transparent"
                TextColor="{StaticResource TextPrimary}"
                Clicked="BtnVoltar_Clicked" />

            <Label
                Grid.Column="1"
                Text="Novo Caso Clínico"
                Style="{StaticResource SubHeadline}"
                FontSize="18"
                HorizontalOptions="Start"
                HorizontalTextAlignment="Start"
                VerticalOptions="Center" />

        </Grid>

        <VerticalStackLayout
            Grid.Row="1"
            VerticalOptions="Center"
            HorizontalOptions="Center">
            <Label
                Text="PostPage"
                TextColor="{StaticResource TextSecondary}" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
