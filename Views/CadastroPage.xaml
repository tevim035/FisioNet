<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FIsioNet.Views.CadastroPage"
             Title="Cadastro"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0" VerticalOptions="Center">
            <VerticalStackLayout Padding="40,20,40,20">
                <Label Text="Criar conta" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Black" Margin="0,0,0,30" SemanticProperties.HeadingLevel="Level1" />

                <!-- Formulário -->
                <VerticalStackLayout Spacing="12">
                    <Border BackgroundColor="#FAFAFA" Stroke="#DBDBDB" StrokeThickness="1" StrokeShape="RoundRectangle 5" HeightRequest="48">
                        <Entry x:Name="EntryNome" Placeholder="Nome completo" FontSize="14" BackgroundColor="Transparent" TextColor="Black" Margin="10,0" />
                    </Border>
                    <Border BackgroundColor="#FAFAFA" Stroke="#DBDBDB" StrokeThickness="1" StrokeShape="RoundRectangle 5" HeightRequest="48">
                        <Entry x:Name="EntryEmail" Placeholder="Email" Keyboard="Email" FontSize="14" BackgroundColor="Transparent" TextColor="Black" Margin="10,0" />
                    </Border>
                    <Border BackgroundColor="#FAFAFA" Stroke="#DBDBDB" StrokeThickness="1" StrokeShape="RoundRectangle 5" HeightRequest="48">
                        <Entry x:Name="EntrySenha" Placeholder="Senha" IsPassword="True" FontSize="14" BackgroundColor="Transparent" TextColor="Black" Margin="10,0" />
                    </Border>
                    <Border BackgroundColor="#FAFAFA" Stroke="#DBDBDB" StrokeThickness="1" StrokeShape="RoundRectangle 5" HeightRequest="48">
                        <Entry x:Name="EntryConfirmarSenha" Placeholder="Confirmar senha" IsPassword="True" FontSize="14" BackgroundColor="Transparent" TextColor="Black" Margin="10,0" />
                    </Border>
                </VerticalStackLayout>

                <Button x:Name="BtnCadastrar" Text="Cadastrar" BackgroundColor="#2A7B4A" TextColor="White" CornerRadius="8" HeightRequest="45" FontAttributes="Bold" FontSize="14" Margin="0,25,0,0" Clicked="BtnCadastrar_Clicked" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- RODAPÉ -->
        <VerticalStackLayout Grid.Row="1">
            <BoxView HeightRequest="1" Color="#DBDBDB" />
            <HorizontalStackLayout HorizontalOptions="Center" Padding="0,15,0,25" Spacing="4">
                <Label Text="Já tem uma conta?" TextColor="#8E8E8E" FontSize="13" VerticalOptions="Center" />
                <Label Text="Entrar" TextColor="#2A7B4A" FontSize="13" FontAttributes="Bold" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVoltarParaLoginTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
