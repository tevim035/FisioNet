<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FIsioNet.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FIsioNet"
    xmlns:views="clr-namespace:FIsioNet.Views"
    Title="FIsioNet">

    <ShellContent
        Title="LoginPage"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="FeedPage"
        ContentTemplate="{DataTemplate views:FeedPage}"
        Route="FeedPage" />
    <ShellContent
        Title="PostPage"
        ContentTemplate="{DataTemplate views:PostPage}"
        Route="PostPage"/>
    <ShellContent
        Title="ProfilePage"
        ContentTemplate="{DataTemplate views:ProfilePage}"
        Route="ProfilePage" />

</Shell>
